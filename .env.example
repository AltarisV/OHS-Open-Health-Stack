# Copy this file to .env and fill in your values.

EHRBASE_USER_PASSWORD=change_me
EHRBASE_DB_PASSWORD=change_me
EHRBASE_ADMIN_PASSWORD=change_me
EOS_DB_PASSWORD=change_me
REDIS_PASSWORD=change_me

# MongoDB password for the openfhir user.
# This is interpolated into the full connection URI automatically.
OPENFHIR_MONGO_PASSWORD=change_me

# ── Cohort Explorer + Keycloak (Phase 12) ─────────────────────────────────────
# Only required when keycloak.enabled / cohort-explorer-*.enabled are true.

KEYCLOAK_ADMIN_PASSWORD=change_me
KEYCLOAK_DB_PASSWORD=change_me

# Client secret for the num-portal Keycloak client (also used for realm auto-import).
# Generate with: openssl rand -base64 32
NUMPORTAL_KEYCLOAK_SECRET=change_me

NUMPORTAL_DB_PASSWORD=change_me

# Secret used by the backend for pseudonymity / privacy masking.
# Generate with: openssl rand -base64 32
NUMPORTAL_PSEUDONYMITY_SECRET=change_me
